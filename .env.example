DATABASE_URL="postgresql://usuario:password@host:5432/basededatos"
SESSION_SECRET="genera-una-cadena-larga-y-aleatoria-aqui"
# Opcional: sin esto, los correos (recuperar contraseña, recordatorios) solo se
# imprimen en la consola en vez de enviarse de verdad. Se consigue en resend.com.
