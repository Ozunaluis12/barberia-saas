# Opcional: sin esto, los recordatorios de WhatsApp solo se imprimen en la
# consola. Se consiguen en la consola de Twilio (twilio.com).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
# Opcional: sin esto, las fotos de personal/servicios/productos no se suben
# (el formulario funciona igual, solo no guarda imagen). Se consiguen en el
# dashboard de cloudinary.com.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
