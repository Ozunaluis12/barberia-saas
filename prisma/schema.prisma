generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// La marca/dueño completo. Puede tener una o varias sucursales (Business).
// Los clientes y su historial de sanciones viven aquí, no en la sucursal,
// para que se compartan entre todas las ubicaciones del mismo dueño.
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  locations Business[]
  clients   Client[]
}

// Una sucursal/ubicación física: barbería, salón, spa, clínica, veterinaria,
// taller, gimnasio, etc. Cada una tiene su propio personal, servicios y
// horarios, y su propia página pública de reservas.
model Business {
  id                      String   @id @default(cuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                    String
  slug                    String   @unique
  category                String   @default("BARBERSHOP") // BARBERSHOP, HAIR_SALON, SPA
  phone                   String?
  address                 String?
  plan                    String   @default("GRATIS") // GRATIS, PRO
  cancellationNoticeHours Int      @default(3)
  reminderChannel         String   @default("NONE") // NONE, EMAIL, SMS, WHATSAPP
  reminderHoursBefore     Int      @default(24)
  onlinePaymentsEnabled   Boolean  @default(false) // reservado para cuando se conecte un proveedor de pagos real
  createdAt               DateTime @default(now())

  users        User[]
  staff        Staff[]
  services     Service[]
  appointments Appointment[]
  reviews      Review[]
}

// Historial de un cliente a nivel de organización: si canceló tarde o no
// llegó en una sucursal, se ve en todas las sucursales del mismo dueño.
model Client {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  strikes        Int      @default(0) // cancelaciones tardías + no-shows
  createdAt      DateTime @default(now())

  appointments Appointment[]
  reviews      Review[]

  @@unique([organizationId, phone])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OWNER") // OWNER (ve/administra todas las sucursales) o STAFF (asignado a una sola)
  active       Boolean  @default(true)
  businessId   String // sucursal "de origen"; el dueño puede cambiar de sucursal activa dentro de su sesión
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  resetTokens PasswordResetToken[]
}

// Token de un solo uso para el flujo de "olvidé mi contraseña". Se guarda el hash,
// nunca el token en texto plano (igual que con las contraseñas).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Un miembro del personal (barbero, estilista, doctor, veterinario, entrenador, técnico...).
// El cliente puede elegirlo por nombre o dejar que el sistema asigne a quien tenga menos carga.
model Staff {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name              String
  active            Boolean  @default(true)
  commissionPercent Int? // null = este negocio no maneja comisión por empleado
  workStart         String   @default("09:00") // HH:mm
  workEnd           String   @default("19:00") // HH:mm
  workDays          String   @default("1,2,3,4,5,6") // 0=domingo..6=sábado
  createdAt         DateTime @default(now())

  appointments Appointment[]
  reviews      Review[]
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int      @default(30)
  price           Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  appointments Appointment[]
}

model Appointment {
  id                String      @id @default(cuid())
  businessId        String
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId           String
  staff             Staff       @relation(fields: [staffId], references: [id])
  serviceId         String
  service           Service     @relation(fields: [serviceId], references: [id])
  clientId          String
  client            Client      @relation(fields: [clientId], references: [id])
  clientName        String
  clientPhone       String
  startTime         DateTime
  endTime           DateTime
  status            String      @default("CONFIRMED") // CONFIRMED, CANCELLED, COMPLETED, NO_SHOW
  source            String      @default("ONLINE") // ONLINE, WALK_IN
  anyStaffRequested Boolean     @default(false)
  lateCancellation  Boolean     @default(false)
  priceCharged      Float? // snapshot del precio del servicio al momento de la reserva
  paymentMethod     String      @default("UNPAID") // UNPAID, CASH, CARD_IN_PERSON, ONLINE
  paymentStatus     String      @default("PENDING") // PENDING, PAID, REFUNDED
  reminderSentAt    DateTime? // evita mandar el mismo recordatorio dos veces
  createdAt         DateTime    @default(now())
  review            Review?

  @@index([staffId, startTime])
  @@index([businessId, startTime])
}

// Reseña que un cliente deja después de una cita completada.
model Review {
  id            String      @id @default(cuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  staffId       String?
  staff         Staff?      @relation(fields: [staffId], references: [id])
  rating        Int // 1 a 5
  comment       String?
  createdAt     DateTime    @default(now())
}
