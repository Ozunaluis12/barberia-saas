generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// La marca/dueño completo. Puede tener una o varias sucursales (Business).
// Los clientes y su historial de sanciones viven aquí, no en la sucursal,
// para que se compartan entre todas las ubicaciones del mismo dueño.
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  locations Business[]
  clients   Client[]
}

// Una sucursal/ubicación física: barbería, salón, spa, clínica, veterinaria,
// taller, gimnasio, etc. Cada una tiene su propio personal, servicios y
// horarios, y su propia página pública de reservas.
model Business {
  id                      String   @id @default(cuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                    String
  slug                    String   @unique
  category                String   @default("BARBERSHOP") // BARBERSHOP, HAIR_SALON, SPA
  phone                   String?
  address                 String?
  plan                    String   @default("GRATIS") // GRATIS, PRO
  cancellationNoticeHours Int      @default(3)
  reminderChannel         String   @default("NONE") // NONE, EMAIL, SMS, WHATSAPP
  reminderHoursBefore     Int      @default(24)
  onlinePaymentsEnabled   Boolean  @default(false) // reservado para cuando se conecte un proveedor de pagos real
  loyaltyEnabled          Boolean  @default(false)
  loyaltyPointsPerVisit   Int      @default(1)
  loyaltyRewardThreshold  Int      @default(10)
  createdAt               DateTime @default(now())

  users        User[]
  staff        Staff[]
  services     Service[]
  products     Product[]
  appointments Appointment[]
  reviews      Review[]
  cashSessions   CashSession[]
  productSales   ProductSale[]
  payrollPayouts PayrollPayout[]
  waitlistEntries WaitlistEntry[]
}

// Historial de un cliente a nivel de organización: si canceló tarde o no
// llegó en una sucursal, se ve en todas las sucursales del mismo dueño.
model Client {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  strikes        Int      @default(0) // cancelaciones tardías + no-shows
  loyaltyPoints  Int      @default(0)
  marketingOptIn Boolean  @default(true) // recibe difusión masiva de WhatsApp; ya recibe recordatorios igual
  createdAt      DateTime @default(now())

  appointments Appointment[]
  reviews      Review[]

  @@unique([organizationId, phone])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OWNER") // OWNER (ve/administra todas las sucursales) o STAFF (asignado a una sola)
  permissions  String   @default("") // CSV para cuentas STAFF: staff,catalog,reports,settings (Equipo y Sucursales son siempre exclusivas del dueño)
  active       Boolean  @default(true)
  businessId   String // sucursal "de origen"; el dueño puede cambiar de sucursal activa dentro de su sesión
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  resetTokens    PasswordResetToken[]
  openedSessions CashSession[]
  productSales   ProductSale[]
  payrollPayouts PayrollPayout[]
}

// Token de un solo uso para el flujo de "olvidé mi contraseña". Se guarda el hash,
// nunca el token en texto plano (igual que con las contraseñas).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Un miembro del personal (barbero, estilista, doctor, veterinario, entrenador, técnico...).
// El cliente puede elegirlo por nombre o dejar que el sistema asigne a quien tenga menos carga.
model Staff {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name              String
  photoUrl          String?
  active            Boolean  @default(true)
  commissionPercent Int? // null = este negocio no maneja comisión por empleado
  workStart         String   @default("09:00") // HH:mm
  workEnd           String   @default("19:00") // HH:mm
  workDays          String   @default("1,2,3,4,5,6") // 0=domingo..6=sábado
  createdAt         DateTime @default(now())

  appointments    Appointment[]
  reviews         Review[]
  cashSessions    CashSession[]
  timeOff         StaffTimeOff[]
  payrollPayouts  PayrollPayout[]
  waitlistEntries WaitlistEntry[]
}

// Rango de fechas en el que un miembro del personal no trabaja (vacaciones,
// incapacidad) — excepción puntual al horario semanal fijo de Staff.workDays.
model StaffTimeOff {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([staffId, startDate, endDate])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  imageUrl        String?
  durationMinutes Int      @default(30)
  price           Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]
}

// Producto físico que el negocio vende además de sus servicios (ej. shampoo,
// cera, cremas). No participa en el flujo de reserva de citas — es solo
// catálogo/venta directa en el local.
model Product {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  price       Float
  stock       Int? // null = no se trackea inventario para este producto
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  sales ProductSale[]
}

// Venta puntual de un producto (no participa del flujo de citas). Descuenta
// stock si el producto lo trackea, y alimenta el esperado de caja cuando el
// pago fue en efectivo.
model ProductSale {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quantity      Int
  unitPrice     Float
  total         Float
  paymentMethod String // CASH, CARD_IN_PERSON
  soldByUserId  String
  soldBy        User     @relation(fields: [soldByUserId], references: [id])
  createdAt     DateTime @default(now())

  @@index([businessId, createdAt])
}

model Appointment {
  id                String      @id @default(cuid())
  businessId        String
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId           String
  staff             Staff       @relation(fields: [staffId], references: [id])
  serviceId         String
  service           Service     @relation(fields: [serviceId], references: [id])
  clientId          String
  client            Client      @relation(fields: [clientId], references: [id])
  clientName        String
  clientPhone       String
  startTime         DateTime
  endTime           DateTime
  status            String      @default("CONFIRMED") // CONFIRMED, CANCELLED, COMPLETED, NO_SHOW
  source            String      @default("ONLINE") // ONLINE, WALK_IN
  anyStaffRequested Boolean     @default(false)
  lateCancellation  Boolean     @default(false)
  priceCharged      Float? // snapshot del precio del servicio al momento de la reserva
  paymentMethod     String      @default("UNPAID") // UNPAID, CASH, CARD_IN_PERSON, ONLINE
  paymentStatus     String      @default("PENDING") // PENDING, PAID, REFUNDED
  paidAt            DateTime? // cuándo se marcó como pagada (para acotar sesiones de caja)
  reminderSentAt    DateTime? // evita mandar el mismo recordatorio dos veces
  createdAt         DateTime    @default(now())
  review            Review?

  @@index([staffId, startTime])
  @@index([businessId, startTime])
}

// Reseña que un cliente deja después de una cita completada.
model Review {
  id            String      @id @default(cuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  staffId       String?
  staff         Staff?      @relation(fields: [staffId], references: [id])
  rating        Int // 1 a 5
  comment       String?
  createdAt     DateTime    @default(now())
}

// Sesión de caja: apertura y cierre de un turno, por empleado o general
// (staffId null). Se calcula lo esperado (efectivo cobrado en la ventana de
// la sesión) contra lo contado físicamente, y la diferencia queda guardada
// para siempre — no solo mientras la caja está abierta.
model CashSession {
  id             String    @id @default(cuid())
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId        String?
  staff          Staff?    @relation(fields: [staffId], references: [id])
  openedByUserId String
  openedBy       User      @relation(fields: [openedByUserId], references: [id])
  openingAmount  Float     @default(0)
  countedAmount  Float?
  expectedAmount Float?
  difference     Float?
  notes          String?
  status         String    @default("OPEN") // OPEN, CLOSED
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  @@index([businessId, status])
}

// Cierre congelado de un período de nómina/comisión para un miembro del
// personal: evita recalcular (y pagar dos veces) el mismo rango de fechas.
model PayrollPayout {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId           String
  staff             Staff    @relation(fields: [staffId], references: [id])
  periodStart       DateTime
  periodEnd         DateTime
  revenue           Float
  commissionPercent Int?
  commissionAmount  Float
  paidByUserId      String
  paidBy            User     @relation(fields: [paidByUserId], references: [id])
  createdAt         DateTime @default(now())

  @@index([businessId, staffId, periodStart])
}

// Cliente que quiere avisarse si se libera un horario en un día que ya no
// tenía cupo. notifiedAt marca que ya se le avisó (para no repetir el aviso).
model WaitlistEntry {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id])
  staffId     String?
  staff       Staff?    @relation(fields: [staffId], references: [id])
  day         String // YYYY-MM-DD
  clientName  String
  clientPhone String
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([businessId, day])
}
